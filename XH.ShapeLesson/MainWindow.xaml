<Window x:Class="XH.ShapeLesson.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XH.ShapeLesson"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Line X1="10" Y1="10" X2="100" Y2="100"
                  Stroke="Red" 
                  StrokeThickness="2"
                  Fill="Orange"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top" />
            <Rectangle Width="100" Height="50" Fill="Orange"  RadiusX="30" RadiusY="30" />
            <Polyline Points="20 20 30 80 100 20 " Fill="Orange" Stroke="Red" />
            <Polygon Points="20 20 30 80 100 20 " Fill="Orange" Stroke="Red" />
        </StackPanel>

    </Grid>
</Window>
